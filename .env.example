BACKEND_PORT=8000

POSTGRES_HOST=localhost
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=social_support
POSTGRES_PORT=5432

QDRANT_HOST=localhost
QDRANT_PORT=6333
QDRANT_COLLECTION=chunk_collection

REDIS_HOST=localhost
REDIS_PORT=6379

SBER_TOKEN_URL=
SBER_REDIRECT_URI=
SBER_USERINFO_URL=
CLIENT_ID=
CLIENT_SECRET=
SBER_SCOPES=
SBER_APPLICATION_NAME=

FRONTEND_AUTH_REDIRECT_URL=

JWT_ACCESS_SECRET=your-access-secret-key-change-me
JWT_REFRESH_SECRET=your-refresh-secret-key-change-me

LLM_PROVIDER=gigachat

POLZA_AI_API_KEY=
POLZA_AI_BASE_URL=https://polza.ai/api/v1
POLZA_AI_MODEL=xiaomi/mimo-v2-flash

GIGACHAT_API_KEY=
GIGACHAT_SCOPE=
GIGACHAT_MODEL=

LLM_SOURCE_TEXT_LIMIT=3000
LLM_FALLBACK_CONTEXT_LIMIT=1000

LLM_GENERATE_TEMPERATURE=0.3
LLM_GENERATE_MAX_TOKENS=2048

LLM_COMPRESS_TEMPERATURE=0.2
LLM_COMPRESS_MAX_TOKENS=512

LLM_TIMEOUT=60.0

VITE_API_URL=

# ----------------------------------------------------------------------
# Admin panel (separate FastAPI service mounted at /admin/ behind nginx).
# Generate fresh secrets — never reuse the user-facing JWT secrets above.
# ----------------------------------------------------------------------
ADMIN_JWT_SECRET=change-me-different-from-user-jwt
ADMIN_SESSION_TTL_MINUTES=120
ADMIN_CSRF_SECRET=change-me-32-random-bytes

# Bootstrap admin (created on first start when admins table is empty).
# The account is forced to change its password at first login.
INITIAL_ADMIN_USERNAME=admin
INITIAL_ADMIN_PASSWORD=change-me-on-first-login

# Login throttle (Redis-backed, per username + per IP).
ADMIN_LOGIN_RATE_LIMIT_ATTEMPTS=5
ADMIN_LOGIN_RATE_LIMIT_WINDOW_SECONDS=900
ADMIN_LOCKOUT_SECONDS=900

# Set to true behind HTTPS so cookies are Secure and HSTS is sent.
# Leave false for local HTTP development.
ADMIN_FORCE_HTTPS=false

ADMIN_TOTP_ISSUER=SOC Admin

# Public mount path of the admin service behind nginx. When the admin
# service is reached through nginx at /admin/, set this so links,
# redirects, and cookies stay inside that namespace. Leave empty if
# you point a browser directly at the admin container (port 8001).
ADMIN_BASE_PATH=/admin

# ----------------------------------------------------------------------
# nginx Basic Auth file for the /admin/ location is operator-generated:
#     htpasswd -B -c nginx/admin.htpasswd admin
# (the file is gitignored; bind-mounted into the nginx container).
# ----------------------------------------------------------------------
