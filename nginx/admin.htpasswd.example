# nginx Basic Auth credentials for the admin panel.
#
# This is the sample only. The real file lives at ./nginx/admin.htpasswd
# (gitignored) and is bind-mounted into the nginx container as
# /etc/nginx/admin.htpasswd.
#
# Generate the real file with:
#   htpasswd -B -c nginx/admin.htpasswd admin
#
# Add additional users with:
#   htpasswd -B nginx/admin.htpasswd <username>
#
# Each line is "<username>:<bcrypt-hash>" (use -B for bcrypt; -m / -d / -s
# are weaker and should not be used).
#
# Remember: this is the OUTER ring — IP allowlist + Basic Auth in nginx.
# The admin service itself enforces Argon2 passwords, JWT sessions,
# optional TOTP, CSRF, and rate limiting on the application side.

admin:$2y$05$REPLACE_THIS_WITH_AN_HTPASSWD_GENERATED_HASH....................
